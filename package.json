{
  "name": "ai-calendar",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "start": "npm start -w client",
    "android": "npm run android -w client",
    "ios": "npm run ios -w client",
    "web": "npm run web -w client",
    "server": "npm run dev -w server",
    "test": "npm test -w client",
    "test:server": "npm test -w server",
    "test:all": "npm test -w client && npm test -w server",
    "typecheck": "npm run typecheck -w client && npm run typecheck -w server",
    "typecheck:client": "npm run typecheck -w client",
    "typecheck:server": "npm run typecheck -w server",
    "lint": "npm run lint -w client && npm run lint -w server",
    "lint:client": "npm run lint -w client",
    "lint:server": "npm run lint -w server"
  }
}
