{
  "name": "ai-calendar-server",
  "private": true,
  "scripts": {
    "dev": "node --env-file=../.env ../node_modules/.bin/next dev --port 4399",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "node --env-file=../.env ../node_modules/.bin/tsx scripts/migrate.ts",
    "reset-db": "node --env-file=../.env ../node_modules/.bin/tsx scripts/reset-db.ts && node --env-file=../.env ../node_modules/.bin/tsx scripts/migrate.ts",
    "db:generate": "node --env-file=../.env ../node_modules/.bin/drizzle-kit generate",
    "db:migrate": "node --env-file=../.env ../node_modules/.bin/drizzle-kit migrate",
    "db:push": "node --env-file=../.env ../node_modules/.bin/drizzle-kit push",
    "db:studio": "node --env-file=../.env ../node_modules/.bin/drizzle-kit studio"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "ai": "^6.0.116",
    "drizzle-orm": "^0.45.1",
    "expo-server-sdk": "^3.13.0",
    "next": "^15.3.3",
    "pg": "^8.20.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.1"
  }
}
